{
  "id": "po32-drum",
  "name": "Libpo32",
  "description": "Drum synthesizer powered by libpo32",
  "version": "1.0.2",
  "author": "mestela",
  "capabilities": {
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Libpo32",
          "count_param": "kit_count",
          "list_param": "kit",
          "name_param": "kit_name",
          "params": [
            {
              "key": "kit",
              "name": "Kit",
              "type": "int",
              "min": 0,
              "max": 31,
              "default": 0
            },
            {
              "key": "level",
              "name": "Level",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "decay",
              "name": "Decay",
              "type": "float",
              "min": 0.1,
              "max": 3.0,
              "default": 1.0,
              "step": 0.05
            }
          ],
          "knobs": [
            "kit",
            "level",
            "decay"
          ]
        }
      }
    }
  }
}
